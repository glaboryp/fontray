{
    "$schema": "https://json.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "lint": "eslint resources/js --ext .js,.vue --fix",
        "lint:check": "eslint resources/js --ext .js,.vue",
        "format": "prettier --write \"resources/js/**/*.{js,vue}\" \"resources/css/**/*.css\"",
        "format:check": "prettier --check \"resources/js/**/*.{js,vue}\" \"resources/css/**/*.css\"",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:e2e": "playwright test"
    },
    "devDependencies": {
        "@inertiajs/vue3": "^2.0.0",
        "@playwright/test": "^1.59.1",
        "@tailwindcss/forms": "^0.5.3",
        "@tailwindcss/vite": "^4.0.0",
        "@vitejs/plugin-vue": "^6.0.0",
        "@vue/eslint-config-prettier": "^10.2.0",
        "@vue/test-utils": "^2.4.6",
        "autoprefixer": "^10.4.12",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "eslint": "^9.34.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.4",
        "eslint-plugin-vue": "^10.4.0",
        "happy-dom": "^20.8.9",
        "laravel-vite-plugin": "^2.0.0",
        "postcss": "^8.4.31",
        "prettier": "^3.6.2",
        "tailwindcss": "^3.2.1",
        "vite": "^7.0.4",
        "vitest": "^4.1.3",
        "vue": "^3.4.0"
    },
    "dependencies": {
        "@inertiajs/vue3": "^2.1.3",
        "vue-advanced-cropper": "^2.8.9"
    }
}
